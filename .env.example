# =============================================================================
# Byzantium AI Agent Trust Verification Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running locally.
# In production, inject these via your secret manager (Kubernetes Secrets,
# AWS Secrets Manager, HashiCorp Vault, etc.). NEVER commit a populated .env.
#
# Legend:
#   [REQUIRED] — must be set; the service will fail to start or misbehave without it
#   [OPTIONAL] — has a sensible default shown; override when needed
# =============================================================================


# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------

# Interface the HTTP gateway binds to.
# Use 0.0.0.0 in containers, 127.0.0.1 for local-only access.
# [OPTIONAL] Default: 0.0.0.0
GATEWAY_HOST=0.0.0.0

# TCP port the gateway listens on.
# [OPTIONAL] Default: 8080
GATEWAY_PORT=8080

# Comma-separated list of Bearer API keys accepted by the gateway.
# Callers must send: Authorization: Bearer <key>
# Generate with: openssl rand -hex 32
# Example: "key_abc123,key_def456"
# [REQUIRED]
BYZ_API_KEYS=change_me_key1,change_me_key2

# Comma-separated list of origins allowed by CORS.
# Use "*" for development only — production MUST list specific origins.
# Example: "https://app.example.com,https://admin.example.com"
# [OPTIONAL] Default: http://localhost:3000
BYZ_CORS_ORIGINS=*

# Maximum trust-check requests per minute per source IP.
# Set to 0 to disable rate limiting at the application layer (not recommended
# in production; rely on nginx/load-balancer limits instead).
# [OPTIONAL] Default: 600
RATE_LIMIT_PER_MIN=600

# Optional: protect /metrics with a Bearer token (recommended in production)
# BYZ_METRICS_TOKEN=your-prometheus-scrape-token

# How often (in seconds) the background task refreshes the reputation proof
# cache from the proof store.
# [OPTIONAL] Default: 60
PROOF_REFRESH_SECS=60


# -----------------------------------------------------------------------------
# PostgreSQL (primary relational store)
# -----------------------------------------------------------------------------

# Full libpq-style connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# [REQUIRED]
DATABASE_URL=postgres://byzantium:changeme@localhost:5432/byzantium


# -----------------------------------------------------------------------------
# Redis (proof cache & rate-limit counters)
# -----------------------------------------------------------------------------

# Redis connection URL.
# Use rediss:// for TLS-encrypted connections in production.
# [REQUIRED]
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# Neo4j (trust-graph store)
# -----------------------------------------------------------------------------

# Bolt URI for the Neo4j instance.
# Use neo4j+s:// or bolt+s:// for encrypted connections in production.
# [REQUIRED]
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication credentials.
# [REQUIRED]
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme


# -----------------------------------------------------------------------------
# ImmuDB (tamper-evident audit log)
# -----------------------------------------------------------------------------

# Hostname or IP of the ImmuDB server.
# [REQUIRED]
IMMUDB_HOST=localhost

# ImmuDB gRPC credentials.
# [REQUIRED]
IMMUDB_USERNAME=immudb
IMMUDB_PASSWORD=changeme

# Logical database name within ImmuDB for Byzantium records.
# [OPTIONAL] Default: byzantium
IMMUDB_DATABASE=byzantium


# -----------------------------------------------------------------------------
# zkMe (zero-knowledge identity verification)
# -----------------------------------------------------------------------------

# Base URL of the zkMe API. Override only when using a private/testnet instance.
# [OPTIONAL] Default: https://api.zkme.io
ZKME_API_URL=https://api.zkme.io

# API key issued by zkMe for your organisation.
# [REQUIRED for identity verification features]
ZKME_API_KEY=changeme


# -----------------------------------------------------------------------------
# Blockchain / On-Chain Anchoring (Base L2)
# -----------------------------------------------------------------------------

# RPC endpoint for the Base L2 network.
# Used for EIP-3009 payment rails and on-chain trust anchoring.
# Examples:
#   https://mainnet.base.org          (public, rate-limited)
#   https://base-mainnet.g.alchemy.com/v2/<key>  (recommended for production)
# [REQUIRED for on-chain features]
BASE_RPC_URL=https://mainnet.base.org


# -----------------------------------------------------------------------------
# SP1 ZK Prover (Succinct)
# -----------------------------------------------------------------------------

# Prover execution mode.
#   local   — proofs run in-process (slow; suitable for development/CI only)
#   network — proofs delegated to Succinct's prover network (production)
# [OPTIONAL] Default: local
SP1_PROVER=local

# Ed25519 private key for authenticating with the Succinct prover network.
# Only required when SP1_PROVER=network.
# Generate with the `sp1up` toolchain.
# [REQUIRED when SP1_PROVER=network]
SP1_PRIVATE_KEY=


# -----------------------------------------------------------------------------
# Trusted Execution Environment (TEE)
# -----------------------------------------------------------------------------

# Enable TEE-backed signing and remote attestation for the reputation and
# mandate engines. Requires hardware with Intel SGX/TDX support
# (e.g., Azure DCsv3 / DCdsv3 instances).
# [OPTIONAL] Default: false
BYZ_TEE_ENABLED=false

# gRPC port the mandate engine TEE sidecar listens on.
# [OPTIONAL] Default: 50051
MANDATE_ENGINE_PORT=50051

# gRPC port the reputation TEE sidecar listens on.
# [OPTIONAL] Default: 50052
REPUTATION_TEE_PORT=50052


# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------

# OpenTelemetry (optional — remove to disable tracing export)
# When set, spans are exported via OTLP/gRPC to the specified collector.
# Start Jaeger locally: docker compose --profile observability up jaeger
# then open http://localhost:16686 to browse traces.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Tracing filter for tracing-subscriber's EnvFilter.
# Format: [target=]level[,...]
# See: https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
# Examples:
#   info                                — info level for all targets
#   byzantium=debug,tower_http=info     — debug for Byzantium crates only
#   warn,byz_gateway=trace              — trace the gateway, warn everything else
# [OPTIONAL] Default: info
RUST_LOG=info


# -----------------------------------------------------------------------------
# Alertmanager
# -----------------------------------------------------------------------------

# Webhook URL where Alertmanager sends firing/resolved notifications.
# Example: a Slack incoming webhook, PagerDuty Events API v2 endpoint, etc.
# Start Alertmanager: docker compose --profile observability up alertmanager
# then open http://localhost:9093 to browse active alerts.
# [REQUIRED when Alertmanager is enabled]
# ALERTMANAGER_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Optional Bearer token sent in the Authorization header of webhook requests.
# Leave blank if your webhook endpoint does not require authentication.
# [OPTIONAL]
# ALERTMANAGER_WEBHOOK_TOKEN=


# -----------------------------------------------------------------------------
# TLS / Domain
# -----------------------------------------------------------------------------

# Public domain name for the Byzantium gateway.
# Used by nginx/certbot-setup.sh (bare-metal) and cert-manager (Kubernetes).
# [REQUIRED for TLS]
BYZANTIUM_DOMAIN=api.yourdomain.com

# Email address for Let's Encrypt expiry notifications.
# Used by certbot (nginx/certbot-setup.sh) and cert-manager (deploy/k8s/cert-manager/issuer.yaml).
# [REQUIRED for TLS]
CERT_MANAGER_EMAIL=admin@yourdomain.com


# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------

# S3 bucket name for storing PostgreSQL backups.
# The CronJob (deploy/k8s/backup/postgres-backup-cronjob.yaml) uploads daily
# dumps here and prunes backups older than 30 days.
# Leave unset to keep backups pod-local only (not recommended for production).
# [OPTIONAL]
BACKUP_S3_BUCKET=your-backup-bucket-name


# -----------------------------------------------------------------------------
# Billing (Stripe)
# -----------------------------------------------------------------------------

# Stripe secret key for metered billing integration.
# Use sk_test_... for test mode, sk_live_... for production.
# If not set, usage is counted and logged locally but never billed.
# [OPTIONAL]
# STRIPE_SECRET_KEY=sk_test_...

# Metered price ID from the Stripe Dashboard.
# Create via: Products → Add Product → Recurring → Usage-based
# [OPTIONAL — required only when STRIPE_SECRET_KEY is set]
# STRIPE_PRICE_ID=price_...


# -----------------------------------------------------------------------------
# Full observability stack
# -----------------------------------------------------------------------------

# Start Jaeger, Loki, Promtail, and Alertmanager together:
# docker compose --profile observability up
#
# Individual services:
#   docker compose --profile observability up jaeger       # distributed traces  → http://localhost:16686
#   docker compose --profile observability up loki         # log aggregation      → http://loki:3100
#   docker compose --profile observability up promtail     # log shipper (gateway container logs → Loki)
#   docker compose --profile observability up alertmanager # alert routing        → http://localhost:9093
