      },
      "targets": [
        {
          "expr": "rate(byzantium_receipts_issued_total[1m]) * 60",
          "legendFormat": "Receipts / min",
          "refId": "A"
        }
      ],
      "title": "Receipts per Minute",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
