---
# =============================================================================
# Byzantium Gateway — Kubernetes Secret Template
# =============================================================================
#
# THIS IS A TEMPLATE — DO NOT PUT REAL VALUES HERE.
# DO NOT COMMIT A POPULATED VERSION TO SOURCE CONTROL.
#
# Usage options (choose one):
#
#   Option A — kubectl create secret (recommended for CI/CD pipelines):
#     kubectl create secret generic byzantium-secrets \
#       --namespace byzantium \
#       --from-literal=DATABASE_URL="postgres://user:pass@host:5432/db" \
#       --from-literal=BYZ_API_KEYS="key1,key2" \
#       # ... add remaining keys ...
#       --dry-run=client -o yaml | kubectl apply -f -
#
#   Option B — External Secrets Operator (recommended for production):
#     Wire ExternalSecret resources to AWS Secrets Manager, HashiCorp Vault,
#     or GCP Secret Manager. The keys listed below map 1-to-1 to secret paths.
#
#   Option C — Manual YAML (only for isolated, non-shared environments):
#     Base64-encode each value: echo -n "myvalue" | base64
#     Paste the output into the `data:` block below, then:
#       kubectl apply -f secrets.yaml  (keep the file OFF disk afterward)
#
# Key naming mirrors .env.example exactly so values can be interpolated
# directly from any secret manager without renaming.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: byzantium-secrets
  namespace: byzantium
  labels:
    app: byzantium-gateway
    app.kubernetes.io/name: byzantium-gateway
    app.kubernetes.io/part-of: byzantium
  annotations:
    # Increment this annotation when rotating secrets to force a pod rollout.
    byzantium.io/secret-version: "1"
type: Opaque
data:
  # ---------------------------------------------------------------------------
  # Gateway
  # ---------------------------------------------------------------------------

  # GATEWAY_HOST — bind interface (e.g. 0.0.0.0)
  # echo -n "0.0.0.0" | base64
  GATEWAY_HOST: REPLACE_WITH_BASE64_VALUE

  # GATEWAY_PORT — TCP port (e.g. 8080)
  GATEWAY_PORT: REPLACE_WITH_BASE64_VALUE

  # BYZ_API_KEYS — comma-separated Bearer keys; generate with: openssl rand -hex 32
  BYZ_API_KEYS: REPLACE_WITH_BASE64_VALUE

  # RATE_LIMIT_PER_MIN — max requests per minute per IP (e.g. 600)
  RATE_LIMIT_PER_MIN: REPLACE_WITH_BASE64_VALUE

  # PROOF_REFRESH_SECS — proof cache refresh interval in seconds (e.g. 60)
  PROOF_REFRESH_SECS: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # PostgreSQL
  # ---------------------------------------------------------------------------

  # DATABASE_URL — full connection string
  # Format: postgres://<user>:<password>@<host>:<port>/<database>
  DATABASE_URL: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # Redis
  # ---------------------------------------------------------------------------

  # REDIS_URL — connection URL (use rediss:// for TLS)
  REDIS_URL: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # Neo4j
  # ---------------------------------------------------------------------------

  # NEO4J_URI — Bolt URI (use neo4j+s:// or bolt+s:// for TLS in production)
  NEO4J_URI: REPLACE_WITH_BASE64_VALUE

  # NEO4J_USERNAME
  NEO4J_USERNAME: REPLACE_WITH_BASE64_VALUE

  # NEO4J_PASSWORD
  NEO4J_PASSWORD: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # ImmuDB
  # ---------------------------------------------------------------------------

  # IMMUDB_HOST — hostname or IP of the ImmuDB server
  IMMUDB_HOST: REPLACE_WITH_BASE64_VALUE

  # IMMUDB_USERNAME
  IMMUDB_USERNAME: REPLACE_WITH_BASE64_VALUE

  # IMMUDB_PASSWORD
  IMMUDB_PASSWORD: REPLACE_WITH_BASE64_VALUE

  # IMMUDB_DATABASE — logical database name within ImmuDB
  IMMUDB_DATABASE: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # zkMe
  # ---------------------------------------------------------------------------

  # ZKME_API_URL — override only for testnet (default: https://api.zkme.io)
  ZKME_API_URL: REPLACE_WITH_BASE64_VALUE

  # ZKME_API_KEY — issued by zkMe for your organisation
  ZKME_API_KEY: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # Blockchain / On-Chain Anchoring
  # ---------------------------------------------------------------------------

  # BASE_RPC_URL — RPC endpoint for Base L2
  # Example: https://base-mainnet.g.alchemy.com/v2/<your-key>
  BASE_RPC_URL: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # SP1 ZK Prover
  # ---------------------------------------------------------------------------

  # SP1_PROVER — "local" or "network"
  SP1_PROVER: REPLACE_WITH_BASE64_VALUE

  # SP1_PRIVATE_KEY — required only when SP1_PROVER=network
  SP1_PRIVATE_KEY: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # TEE Sidecars
  # ---------------------------------------------------------------------------

  # BYZ_TEE_ENABLED — "true" or "false"
  BYZ_TEE_ENABLED: REPLACE_WITH_BASE64_VALUE

  # MANDATE_ENGINE_PORT — gRPC port of the mandate engine TEE sidecar
  MANDATE_ENGINE_PORT: REPLACE_WITH_BASE64_VALUE

  # REPUTATION_TEE_PORT — gRPC port of the reputation TEE sidecar
  REPUTATION_TEE_PORT: REPLACE_WITH_BASE64_VALUE

  # ---------------------------------------------------------------------------
  # Logging
  # ---------------------------------------------------------------------------

  # RUST_LOG — tracing filter (e.g. "info" or "byzantium=debug,tower_http=info")
  RUST_LOG: REPLACE_WITH_BASE64_VALUE
