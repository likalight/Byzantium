        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "increase(byzantium_daily_cap_violations_total[24h])",
          "legendFormat": "Daily Cap Violations",
          "refId": "A"
        }
      ],
      "title": "Daily Cap Violations",
      "type": "stat"
